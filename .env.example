# =============================================================================
# Playlab Rostering Middleware — Environment Configuration
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# =============================================================================

# ── Run control ───────────────────────────────────────────────────────────────
SOURCE=clever               # clever | classlink | oneroster | all
DELTA=false                 # true = delta/events sync only (not full sync)
LAST_EVENT_ID=              # Clever: ID of last processed event (delta mode)
DRY_RUN=false               # true = normalise + dedup without writing anything
LOG_LEVEL=info              # debug | info | warn | error
LOG_TESTS=false             # true = show logs during test run (default: silent)
RUN_COMPLIANCE_AUDIT=false  # true = run legislative monitoring scan on startup
SYNC_CONCURRENCY=5          # parallel entity processing workers
SYNC_BATCH_SIZE=200         # records per processing batch

# ── Clever API v3.1 ───────────────────────────────────────────────────────────
# Obtain from: https://apps.clever.com → your app → Settings
# CLEVER_DISTRICT_TOKEN: district-app bearer token (Secure Sync integration)
# CLEVER_CLIENT_ID / SECRET: your OAuth 2.0 app credentials (SSO + Secure Sync)
CLEVER_DISTRICT_TOKEN=
CLEVER_CLIENT_ID=
CLEVER_CLIENT_SECRET=

# ── ClassLink OneRoster Proxy ──────────────────────────────────────────────────
# Obtain from: https://developer.classlink.com → your app
# CLASSLINK_APP_ID: your numeric application ID from the ClassLink dev console
CLASSLINK_CLIENT_ID=
CLASSLINK_CLIENT_SECRET=
CLASSLINK_APP_ID=
CLASSLINK_PAGE_SIZE=1000    # records per page (max 1000)

# ── OneRoster 1.1 / 1.2 direct (any certified SIS) ───────────────────────────
# Used when connecting directly to PowerSchool, Infinite Campus, Skyward, etc.
# OR_BASE_URL: base URL of the SIS OneRoster endpoint (no trailing slash)
# OR_TOKEN_URL: OAuth 2.0 token endpoint (Client Credentials Grant)
# OR_VERSION: 1.1 (most common) or 1.2
OR_BASE_URL=
OR_CLIENT_ID=
OR_CLIENT_SECRET=
OR_TOKEN_URL=
OR_VERSION=1.1
OR_PAGE_SIZE=1000

# ── Playlab API ───────────────────────────────────────────────────────────────
# Obtain from: Playlab engineering (provisioning API access is request-only)
# PLAYLAB_BASE_URL: leave as default unless on a custom deployment
PLAYLAB_BASE_URL=https://api.playlab.ai
PLAYLAB_API_KEY=

# ── Database — PostgreSQL (production) ───────────────────────────────────────
# Required for production deployments. Not needed for dev/test (uses in-memory store).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Run migrations first: DATABASE_URL=<url> ts-node scripts/migrate.ts
DATABASE_URL=postgresql://user:password@localhost:5432/playlab_roster

# ── Data residency ────────────────────────────────────────────────────────────
# US deployments: us-east-1 (default)
# EU deployments: eu-west-1  (required for GDPR compliance)
# Australia:      ap-southeast-2
DATA_RESIDENCY_REGION=us-east-1

# ── Compliance audit (optional) ───────────────────────────────────────────────
# Countries/regions to monitor for legislative changes (comma-separated ISO codes)
# The AI Compliance Audit Engine checks these weekly when RUN_COMPLIANCE_AUDIT=true
COMPLIANCE_COUNTRIES=US,DE,GB,AU,CA
