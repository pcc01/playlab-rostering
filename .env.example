# ── Source selection ──────────────────────────────────────────────────────────
SOURCE=clever               # clever | classlink | oneroster | all
DELTA=false                 # true = delta/events sync only
LAST_EVENT_ID=              # Clever: last processed event ID
DRY_RUN=false               # true = no writes to store or Playlab
LOG_LEVEL=info              # debug | info | warn | error
LOG_TESTS=false             # true = enable logging during test run
RUN_COMPLIANCE_AUDIT=false  # true = run weekly legislative scan

# ── Clever ────────────────────────────────────────────────────────────────────
CLEVER_DISTRICT_TOKEN=      # district-app bearer token (Secure Sync)
CLEVER_CLIENT_ID=           # OAuth app client_id
CLEVER_CLIENT_SECRET=       # OAuth app client_secret

# ── ClassLink ─────────────────────────────────────────────────────────────────
CLASSLINK_CLIENT_ID=
CLASSLINK_CLIENT_SECRET=
CLASSLINK_APP_ID=

# ── OneRoster direct ──────────────────────────────────────────────────────────
OR_BASE_URL=                # https://your-sis.example.com
OR_CLIENT_ID=
OR_CLIENT_SECRET=
OR_TOKEN_URL=               # https://your-sis.example.com/oauth/token
OR_VERSION=1.1              # 1.1 | 1.2

# ── Playlab ───────────────────────────────────────────────────────────────────
PLAYLAB_BASE_URL=https://api.playlab.ai
PLAYLAB_API_KEY=

# ── Database (production) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/playlab_roster
